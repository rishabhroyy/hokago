# Copy to .env and edit. See docs/design.md §16.

# Where /config lives on the host (db, artwork, fonts, themes, cache, logs).
# Must be a local POSIX filesystem — not NFS/SMB/exFAT (§16.1).
HOKAGO_CONFIG_DIR=./data/config

POSTGRES_PASSWORD=hokago

HOKAGO_PORT=3000

# linuxserver convention. Applies to the api/worker containers only —
# /config/db is a documented exception, owned by Postgres's own UID (§16.2).
PUID=1000
PGID=1000

TZ=UTC
